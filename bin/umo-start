#!/bin/sh
# UMO — Session Controller [start] (MIT License)
# https://github.com/Shadow-x78/termux-ubuntu-umo

TERMUX_HOME="${HOME:-/data/data/com.termux/files/home}"

_UMO_NC='\033[0m'
_UMO_BOLD='\033[1m'
_UMO_DIM='\033[2m'
_UMO_PRI='\033[38;5;208m'
_UMO_GRN='\033[38;5;34m'
_UMO_CYN='\033[38;5;39m'

termux-wake-lock 2>/dev/null || true

pulseaudio --start 2>/dev/null || true
sleep 1

if [ "$1" = "--x11" ] || [ "$1" = "x11" ]; then
    printf "  %b➜%b  Starting with Termux:X11...\n" "$_UMO_CYN" "$_UMO_NC"
    if ! command -v termux-x11 >/dev/null 2>&1; then
        printf "  %b!%b  termux-x11-nightly not installed.\n" "$_UMO_PRI" "$_UMO_NC"
        printf "  %b\$ pkg install x11-repo && pkg install termux-x11-nightly%b\n" "$_UMO_DIM" "$_UMO_NC"
    fi
    export DISPLAY=:0
    export XDG_RUNTIME_DIR="${TMPDIR:-/tmp}"
    termux-x11 :0 2>/dev/null &
    sleep 2
    exec "$TERMUX_HOME/umo-login.sh" -c "export DISPLAY=:0; export XDG_RUNTIME_DIR=${TMPDIR:-/tmp}; bash"
else
    printf "\n${_UMO_PRI}"
    printf "  ██╗   ██╗███╗   ███╗ ██████╗  \n"
    printf "  ██║   ██║████╗ ████║██╔═══██╗ \n"
    printf "  ██║   ██║██╔████╔██║██║   ██║ \n"
    printf "  ██║   ██║██║╚██╔╝██║██║   ██║ \n"
    printf "  ╚██████╔╝██║ ╚═╝ ██║╚██████╔╝ \n"
    printf "   ╚═════╝ ╚═╝     ╚═╝ ╚═════╝  \n"
    printf "${_UMO_NC}\n"

    printf "  %b[ ⚙ ] Initializing UMO services...%b\n" "$_UMO_DIM" "$_UMO_NC"

    "$TERMUX_HOME/umo-login.sh" -c "umo-startvnc" >/dev/null 2>&1 &
    sleep 3

    IP=$(ip route get 1 2>/dev/null | awk '{print $7; exit}')
    [ -z "$IP" ] && IP="127.0.0.1"

    printf "\033[1A\033[2K"
    printf "  %b────────────────────────────────────────%b\n" "$_UMO_PRI" "$_UMO_NC"
    printf "  %b%b▸ UMO Session Active%b\n" "$_UMO_BOLD" "$_UMO_GRN" "$_UMO_NC"
    printf "  %b────────────────────────────────────────%b\n" "$_UMO_PRI" "$_UMO_NC"
    printf "\n"
    printf "  %bVNC:%b       %b%s:5901%b\n" "$_UMO_BOLD" "$_UMO_NC" "$_UMO_CYN" "$IP" "$_UMO_NC"
    printf "  %bStop:%b      %bumo stop%b\n" "$_UMO_BOLD" "$_UMO_NC" "$_UMO_CYN" "$_UMO_NC"
    printf "  %bStatus:%b    %bumo status%b\n" "$_UMO_BOLD" "$_UMO_NC" "$_UMO_CYN" "$_UMO_NC"
    printf "\n"
    printf "  %b────────────────────────────────────────%b\n" "$_UMO_PRI" "$_UMO_NC"
    printf "\n"
fi

