#!/bin/sh
# UMO — Main Installer (MIT License)
# https://github.com/Shadow-x78/termux-ubuntu-umo

set -e
unset LD_PRELOAD

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
export UMO_LIB_DIR="$SCRIPT_DIR/lib"
export UMO_MOD_DIR="$SCRIPT_DIR/modules"
export UMO_VERSION="3.3.1"

. "$UMO_LIB_DIR/core-ansi.sh"
. "$UMO_LIB_DIR/core-ui.sh"
. "$UMO_LIB_DIR/core-system.sh"
. "$UMO_LIB_DIR/core-net.sh"
. "$UMO_LIB_DIR/core-fs.sh"

. "$UMO_MOD_DIR/umo-proot.sh"
. "$UMO_MOD_DIR/umo-vnc.sh"
. "$UMO_MOD_DIR/umo-audio.sh"
. "$UMO_MOD_DIR/umo-systemctl.sh"
. "$UMO_MOD_DIR/umo-desktop.sh"
. "$UMO_MOD_DIR/umo-apps.sh"

UMO_INSTALL_DIR="${UMO_INSTALL_DIR:-$HOME/umo-ubuntu}"
UMO_UBUNTU_VERSION="${UMO_UBUNTU_VERSION:-22.04}"
UMO_DE="${UMO_DE:-xfce4}"
UMO_APP_SET="${UMO_APP_SET:-basic}"
UMO_PERF_MODE="${UMO_PERF_MODE:-balanced}"
UMO_THEME="${UMO_THEME:-}"
UMO_LEAN="${UMO_LEAN:-0}"
UMO_NON_INTERACTIVE="${UMO_NON_INTERACTIVE:-}"

umo_phase_check() {
    umo_ui_init
    umo_ui_header "System Check"
    umo_sys_require_termux
    umo_sys_setup_storage
    umo_sys_require_arch
    umo_sys_require_internet
    umo_sys_require_space 2048
    umo_sys_summary
}

umo_phase_deps() {
    umo_ui_header "Dependencies"
    _install_deps() {
        _pkg_cmd="apt-get install -y"
        command -v pkg >/dev/null 2>&1 && _pkg_cmd="pkg install -y"
        $_pkg_cmd proot-distro wget tar pulseaudio x11-repo tur-repo git curl unzip >/dev/null 2>&1 || true
        $_pkg_cmd virglrenderer-android termux-x11-nightly >/dev/null 2>&1 || true
    }
    umo_run_quiet "Installing dependencies" _install_deps
}

umo_phase_config() {
    if [ -n "$UMO_NON_INTERACTIVE" ]; then
        umo_log_info "Non-interactive mode: DE=$UMO_DE, Apps=$UMO_APP_SET"
        return 0
    fi

    umo_ui_menu "Choose Ubuntu Version" \
        "Ubuntu 22.04 LTS (Jammy — Stable, Recommended)" \
        "Ubuntu 24.04 LTS (Noble — Latest)"

    case "$UMO_MENU_IDX" in
        1) UMO_UBUNTU_VERSION="22.04" ;;
        2) UMO_UBUNTU_VERSION="24.04" ;;
    esac

    umo_ui_menu "Choose Desktop Environment" \
        "XFCE4 (Recommended — Balanced)" \
        "LXDE (Ultra-Lightweight)" \
        "Openbox (Minimal — Advanced)" \
        "Minimal (CLI only — No GUI)"

    case "$UMO_MENU_IDX" in
        1) UMO_DE="xfce4" ;;
        2) UMO_DE="lxde" ;;
        3) UMO_DE="openbox" ;;
        4) UMO_DE="minimal" ;;
    esac

    umo_ui_menu "Choose Application Set" \
        "Basic (Utilities only)" \
        "Developer (Basic + Python/Node/GCC)" \
        "Media (Basic + VLC/FFmpeg)" \
        "Full Suite (Everything)"

    case "$UMO_MENU_IDX" in
        1) UMO_APP_SET="basic" ;;
        2) UMO_APP_SET="dev" ;;
        3) UMO_APP_SET="media" ;;
        4) UMO_APP_SET="full" ;;
    esac

    umo_ui_header "Configuration Summary"
    umo_kv "Desktop" "$UMO_DE"
    umo_kv "Apps"    "$UMO_APP_SET"
    umo_kv "Install" "$UMO_INSTALL_DIR"
    umo_kv "Version" "Ubuntu $UMO_UBUNTU_VERSION"

    umo_ui_confirm "Confirm installation?" "Y" || {
        umo_log_info "Installation cancelled."
        exit 0
    }
}

umo_phase_download() {
    umo_ui_header "Ubuntu RootFS"
    export UMO_INSTALL_DIR
    export UMO_CACHE_DIR="$HOME/.umo/cache"
    export UMO_UBUNTU_VERSION
    umo_fs_mkdir "$UMO_CACHE_DIR"

    _arch=$(uname -m)
    case "$_arch" in
        aarch64|arm64) _uarch="arm64" ;;
        armv7l|armv8l|arm) _uarch="armhf" ;;
        *) _uarch="arm64" ;;
    esac

    _archive="$UMO_CACHE_DIR/umo-rootfs-${_uarch}.tar.gz"
    umo_net_download_mirrors "$_archive"
    [ -f "$_archive" ] || umo_die "Download reported success but archive is missing: $_archive"
    umo_net_extract "$_archive" "$UMO_INSTALL_DIR"
    rm -f "$_archive"

    if [ ! -f "$UMO_INSTALL_DIR/bin/bash" ] || [ ! -f "$UMO_INSTALL_DIR/bin/sh" ]; then
        umo_die "RootFS extraction failed: /bin/bash or /bin/sh not found. Try a different mirror."
    fi
    umo_log_ok "RootFS integrity verified."
}

umo_phase_proot() {
    umo_ui_header "Proot Container"
    export UMO_INSTALL_DIR
    umo_proot_setup
    umo_proot_create_user
}

umo_phase_vnc() {
    [ "$UMO_DE" = "minimal" ] && { umo_log_info "Skipping VNC (minimal mode)."; return 0; }
    umo_ui_header "Installing VNC Server"
    export UMO_INSTALL_DIR
    umo_vnc_setup
}

umo_phase_audio() {
    umo_ui_header "Configuring Audio Bridge"
    export UMO_INSTALL_DIR
    umo_audio_setup
}

umo_phase_systemctl() {
    umo_ui_header "Installing Systemctl Emulator"
    export UMO_INSTALL_DIR
    umo_systemctl_setup
}

umo_phase_desktop() {
    [ "$UMO_DE" = "minimal" ] && { umo_log_info "Skipping desktop (minimal mode)."; return 0; }
    umo_ui_header "Installing Desktop Environment"
    export UMO_INSTALL_DIR
    export UMO_DE
    umo_de_install
}

umo_phase_apps() {
    umo_ui_header "Installing Applications"
    export UMO_INSTALL_DIR
    export UMO_APP_SET
    umo_apps_install
}

umo_phase_finalize() {
    umo_ui_header "Finalizing Installation"

    _codename="jammy"
    [ "$UMO_UBUNTU_VERSION" = "24.04" ] && _codename="noble"
    _src_list="$SCRIPT_DIR/config/sources.list"
    if [ -f "$_src_list" ] && grep -q 'jammy' "$_src_list" 2>/dev/null; then
        sed '/^deb/ s/jammy/'"$_codename"'/g' "$_src_list" > "$UMO_INSTALL_DIR/etc/apt/sources.list" 2>/dev/null || true
    elif [ -f "$_src_list" ]; then
        cp "$_src_list" "$UMO_INSTALL_DIR/etc/apt/sources.list" 2>/dev/null || true
    fi
    "$HOME/umo-login.sh" -c "apt-get update -qq" 2>/dev/null || true
    "$HOME/umo-login.sh" -c "apt-get install -y sudo" 2>/dev/null || true
    "$HOME/umo-login.sh" -c "dpkg --configure -a" 2>/dev/null || true
    "$HOME/umo-login.sh" -c "usermod -aG sudo umo" 2>/dev/null || true

    for _script in start stop; do
        _src="$SCRIPT_DIR/bin/umo-$_script"
        _dst="$HOME/umo-$_script.sh"
        if [ -f "$_src" ]; then
            cp -f "$_src" "$_dst"
            chmod +x "$_dst"
        fi
    done

    cat > "$HOME/../usr/bin/umo" << 'UMOCMD'
#!/bin/sh
# UMO — Quick launcher (MIT License)
# https://github.com/Shadow-x78/termux-ubuntu-umo
case "${1:-start}" in
    start)  exec "$HOME/umo-start.sh" ;;
    stop)   exec "$HOME/umo-stop.sh" ;;
    login)  exec "$HOME/umo-login.sh" ;;
    user)   exec "$HOME/umo-user.sh" ;;
    vnc)    exec "$HOME/umo-vnc-start.sh" ;;
    help|--help|-h)
        echo "Usage: umo [start|stop|login|user|vnc]"
        echo "  start  — Start Ubuntu + VNC + Audio (default)"
        echo "  stop   — Stop everything"
        echo "  login  — Login as root"
        echo "  user   — Login as umo"
        echo "  vnc    — Start VNC only"
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'umo help' for usage."
        exit 1
        ;;
esac
UMOCMD
    chmod +x "$HOME/../usr/bin/umo"

    umo_log_ok "Installation complete."
}

umo_phase_summary() {
    _ip=$(ip route get 1 2>/dev/null | awk '{print $7; exit}')
    [ -z "$_ip" ] && _ip="127.0.0.1"

    umo_screen_clear
    umo_banner
    umo_rule

    printf "\n  %b%bInstallation Complete%b\n" "$UMO_BOLD" "$UMO_COLOR_SUCCESS" "$UMO_NC"
    printf "  %b" "$UMO_COLOR_PRIMARY"
    umo_repeat "$UMO_LINE_H" 21
    printf "%b\n" "$UMO_NC"

    umo_kv "Version" "Ubuntu $UMO_UBUNTU_VERSION"
    umo_kv "Desktop" "$UMO_DE"
    umo_kv "Path"    "$UMO_INSTALL_DIR"
    umo_kv "VNC"     "$_ip:5901"
    umo_kv "Perf"    "$UMO_PERF_MODE"
    umo_kv "User"    "umo (password: umo)"

    printf "\n%bQuick Commands:%b\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %bumo%b                  Start Ubuntu (alias)\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %b~/umo-start.sh%b       Start Ubuntu + VNC + Audio\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %b~/umo-stop.sh%b        Stop everything\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %b~/umo-vnc-start.sh%b    Start VNC only\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %b~/umo-login.sh%b        Login as root\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %b~/umo-user.sh%b         Login as umo\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"

    printf "\n%bInside Ubuntu:%b\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %bumo-startvnc%b        Start VNC\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %bumo-stopvnc%b         Stop VNC\n" "$UMO_COLOR_PRIMARY" "$UMO_NC"

    _readme_dir="$UMO_INSTALL_DIR/root/.umo"
    umo_fs_mkdir "$_readme_dir" 2>/dev/null || true
    cat > "$_readme_dir/README.txt" 2>/dev/null || true << README_EOF
========================================
  UMO Ubuntu — Welcome!
  Version: $UMO_UBUNTU_VERSION
  Desktop: $UMO_DE
========================================

Quick commands:
  umo                  Start Ubuntu (alias)
  umo-startvnc         Start VNC server
  umo-stopvnc          Stop VNC server
  apt-get update       Update package lists

VNC: $_ip:5901
User: umo / Password: umo
Root: login via ~/umo-login.sh on host

========================================
README_EOF

    printf "\n"
}

umo_cli_parse() {
    for _arg in "$@"; do
        case "$_arg" in
            --no-gui|--non-interactive) UMO_NON_INTERACTIVE=1 ;;
            --de=*)      UMO_DE="${_arg#*=}" ;;
            --apps=*)    UMO_APP_SET="${_arg#*=}" ;;
            --dir=*)     UMO_INSTALL_DIR="${_arg#*=}" ;;
            --ubuntu=*)  UMO_UBUNTU_VERSION="${_arg#*=}" ;;
            --version=*) UMO_UBUNTU_VERSION="${_arg#*=}" ;;
            --perf=*)    UMO_PERF_MODE="${_arg#*=}" ;;
            --theme=*)   UMO_THEME="${_arg#*=}" ;;
            --lean)      UMO_LEAN=1 ;;
            --help|-h)
                cat << 'BANNER'
Usage: umo-install [OPTIONS]

Options:
  --no-gui, --non-interactive   Non-interactive mode
  --de=xfce4|lxde|openbox       Desktop environment
  --apps=basic|dev|media|full   Application set
  --dir=PATH                    Installation directory
  --ubuntu=22.04|24.04          Ubuntu version
  --version=22.04|24.04         (alias for --ubuntu)
  --perf=balanced|aggressive|off Performance level  [default: balanced]
  --theme=umo-dark|umo-light|minimal|none  Desktop theme
  --lean                        Remove docs/man/locales (save space)
  --help, -h                    Show this help
BANNER
                exit 0
                ;;
        esac
    done
}

. "$UMO_MOD_DIR/umo-perf.sh" 2>/dev/null || true

umo_phase_perf() {
    [ "$UMO_PERF_MODE" = "off" ] && { umo_log_info "Performance tuning disabled."; return 0; }
    umo_ui_header "Optimizing Performance"
    export UMO_INSTALL_DIR
    export UMO_PERF_MODE
    export UMO_LEAN
    if command -v umo_perf_setup >/dev/null 2>&1; then
        umo_perf_setup
        umo_log_ok "Performance optimizations applied (mode: $UMO_PERF_MODE)."
    else
        umo_log_warn "Performance module not available, skipping."
    fi
}

. "$UMO_MOD_DIR/umo-theme.sh" 2>/dev/null || true

umo_phase_theme() {
    [ "$UMO_THEME" = "none" ] && { umo_log_info "Theme disabled."; return 0; }
    umo_ui_header "Applying Desktop Theme"
    export UMO_INSTALL_DIR
    export UMO_THEME
    export SCRIPT_DIR
    if command -v umo_theme_setup >/dev/null 2>&1; then
        umo_theme_setup
        umo_log_ok "Desktop theme applied ($UMO_THEME)."
    else
        umo_log_warn "Theme module not available, skipping."
    fi
}

umo_main() {
    umo_cli_parse "$@"

    [ "$UMO_APP_SET" = "full" ] && [ -z "$UMO_THEME" ] && UMO_THEME="umo-dark"

    umo_phase_check
    umo_phase_deps
    umo_phase_config
    umo_phase_download
    umo_phase_proot
    umo_phase_perf
    umo_phase_vnc
    umo_phase_audio
    umo_phase_systemctl
    umo_phase_desktop
    umo_phase_apps
    umo_phase_theme
    umo_phase_finalize
    umo_phase_summary
}

umo_main "$@"
