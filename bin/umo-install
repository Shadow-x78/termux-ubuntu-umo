#!/bin/sh
# UMO — Main Installer (MIT License)
# https://github.com/Shadow-x78/termux-ubuntu-umo

set -e
unset LD_PRELOAD

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
export UMO_LIB_DIR="$SCRIPT_DIR/lib"
export UMO_MOD_DIR="$SCRIPT_DIR/modules"
export UMO_VERSION="3.3.9"

. "$UMO_LIB_DIR/core-ansi.sh"
. "$UMO_LIB_DIR/core-ui.sh"
. "$UMO_LIB_DIR/core-system.sh"
. "$UMO_LIB_DIR/core-net.sh"
. "$UMO_LIB_DIR/core-fs.sh"

. "$UMO_MOD_DIR/umo-proot.sh"
. "$UMO_MOD_DIR/umo-vnc.sh"
. "$UMO_MOD_DIR/umo-audio.sh"
. "$UMO_MOD_DIR/umo-systemctl.sh"
. "$UMO_MOD_DIR/umo-desktop.sh"
. "$UMO_MOD_DIR/umo-apps.sh"

UMO_INSTALL_DIR="${UMO_INSTALL_DIR:-$HOME/umo-ubuntu}"
UMO_UBUNTU_VERSION="${UMO_UBUNTU_VERSION:-22.04}"
UMO_DE="${UMO_DE:-xfce4}"
UMO_APP_SET="${UMO_APP_SET:-basic}"
UMO_PERF_MODE="${UMO_PERF_MODE:-balanced}"
UMO_THEME="${UMO_THEME:-}"
UMO_LEAN="${UMO_LEAN:-0}"
UMO_NON_INTERACTIVE="${UMO_NON_INTERACTIVE:-}"

umo_phase_check() {
    umo_ui_init
    umo_ui_header "System Check"
    umo_sys_require_termux
    umo_sys_setup_storage
    umo_sys_require_arch
    umo_sys_require_internet
    umo_sys_require_space 2048
    umo_sys_summary
}

umo_phase_deps() {
    umo_ui_header "Dependencies"
    _install_deps() {
        _pkg_cmd="apt-get install -y"
        command -v pkg >/dev/null 2>&1 && _pkg_cmd="pkg install -y"
        $_pkg_cmd proot-distro wget tar pulseaudio x11-repo tur-repo git curl unzip >/dev/null 2>&1 || true
        $_pkg_cmd virglrenderer-android termux-x11-nightly >/dev/null 2>&1 || true
    }
    umo_run_quiet "Installing dependencies" _install_deps
}

umo_phase_config() {
    if [ -n "$UMO_NON_INTERACTIVE" ]; then
        umo_log_info "Non-interactive mode: DE=$UMO_DE, Apps=$UMO_APP_SET"
        return 0
    fi

    umo_ui_menu "Choose Ubuntu Version" \
        "Ubuntu 22.04 LTS (Jammy — Stable, Recommended)" \
        "Ubuntu 24.04 LTS (Noble — Latest)"

    case "$UMO_MENU_IDX" in
        1) UMO_UBUNTU_VERSION="22.04" ;;
        2) UMO_UBUNTU_VERSION="24.04" ;;
    esac

    umo_ui_menu "Choose Desktop Environment" \
        "XFCE4 (Recommended — Balanced)" \
        "LXDE (Ultra-Lightweight)" \
        "Openbox (Minimal — Advanced)" \
        "Minimal (CLI only — No GUI)"

    case "$UMO_MENU_IDX" in
        1) UMO_DE="xfce4" ;;
        2) UMO_DE="lxde" ;;
        3) UMO_DE="openbox" ;;
        4) UMO_DE="minimal" ;;
    esac

    umo_ui_menu "Choose Application Set" \
        "Basic (Utilities only)" \
        "Developer (Basic + Python/Node/GCC)" \
        "Media (Basic + VLC/FFmpeg)" \
        "Full Suite (Everything)"

    case "$UMO_MENU_IDX" in
        1) UMO_APP_SET="basic" ;;
        2) UMO_APP_SET="dev" ;;
        3) UMO_APP_SET="media" ;;
        4) UMO_APP_SET="full" ;;
    esac

    umo_ui_header "Configuration Summary"
    umo_kv "Desktop" "$UMO_DE"
    umo_kv "Apps"    "$UMO_APP_SET"
    umo_kv "Install" "$UMO_INSTALL_DIR"
    umo_kv "Version" "Ubuntu $UMO_UBUNTU_VERSION"

    umo_ui_confirm "Confirm installation?" "Y" || {
        umo_log_info "Installation cancelled."
        exit 0
    }
}

umo_phase_download() {
    umo_ui_header "Ubuntu RootFS"
    export UMO_INSTALL_DIR
    export UMO_CACHE_DIR="$HOME/.umo/cache"
    export UMO_UBUNTU_VERSION
    umo_fs_mkdir "$UMO_CACHE_DIR"

    _arch=$(uname -m)
    case "$_arch" in
        aarch64|arm64) _uarch="arm64" ;;
        armv7l|armv8l|arm) _uarch="armhf" ;;
        *) _uarch="arm64" ;;
    esac

    _archive="$UMO_CACHE_DIR/umo-rootfs-${_uarch}.tar.gz"
    umo_net_download_mirrors "$_archive"
    [ -f "$_archive" ] || umo_die "Download reported success but archive is missing: $_archive"
    umo_net_extract "$_archive" "$UMO_INSTALL_DIR"
    rm -f "$_archive"

    if [ ! -f "$UMO_INSTALL_DIR/bin/bash" ] || [ ! -f "$UMO_INSTALL_DIR/bin/sh" ]; then
        umo_die "RootFS extraction failed: /bin/bash or /bin/sh not found. Try a different mirror."
    fi
    umo_log_ok "RootFS integrity verified."
}

umo_phase_proot() {
    umo_ui_header "Proot Container"
    export UMO_INSTALL_DIR
    umo_proot_setup
    umo_proot_create_user
}

umo_phase_vnc() {
    [ "$UMO_DE" = "minimal" ] && { umo_log_info "Skipping VNC (minimal mode)."; return 0; }
    umo_ui_header "VNC Server"
    export UMO_INSTALL_DIR
    umo_vnc_setup
}

umo_phase_audio() {
    umo_ui_header "Audio Bridge"
    export UMO_INSTALL_DIR
    umo_audio_setup
}

umo_phase_systemctl() {
    umo_ui_header "Systemctl Emulator"
    export UMO_INSTALL_DIR
    umo_systemctl_setup
}

umo_phase_desktop() {
    [ "$UMO_DE" = "minimal" ] && { umo_log_info "Skipping desktop (minimal mode)."; return 0; }
    umo_ui_header "Desktop Environment"
    export UMO_INSTALL_DIR
    export UMO_DE
    umo_de_install
}

umo_phase_apps() {
    umo_ui_header "Applications"
    export UMO_INSTALL_DIR
    export UMO_APP_SET
    umo_apps_install
}

umo_phase_finalize() {
    umo_ui_header "Finalizing"

    _codename="jammy"
    [ "$UMO_UBUNTU_VERSION" = "24.04" ] && _codename="noble"
    _src_list="$SCRIPT_DIR/config/sources.list"
    if [ -f "$_src_list" ] && grep -q 'jammy' "$_src_list" 2>/dev/null; then
        sed '/^deb/ s/jammy/'"$_codename"'/g' "$_src_list" > "$UMO_INSTALL_DIR/etc/apt/sources.list" 2>/dev/null || true
    elif [ -f "$_src_list" ]; then
        cp "$_src_list" "$UMO_INSTALL_DIR/etc/apt/sources.list" 2>/dev/null || true
    fi
    "$HOME/umo-login.sh" -c "apt-get update -qq" 2>/dev/null || true
    "$HOME/umo-login.sh" -c "apt-get install -y sudo" 2>/dev/null || true
    "$HOME/umo-login.sh" -c "dpkg --configure -a" 2>/dev/null || true
    "$HOME/umo-login.sh" -c "usermod -aG sudo umo" 2>/dev/null || true

    for _pid in $(pgrep -f "proot" 2>/dev/null); do
        kill "$_pid" 2>/dev/null || true
    done
    wait 2>/dev/null || true

    for _script in start stop; do
        _src="$SCRIPT_DIR/bin/umo-$_script"
        _dst="$HOME/umo-$_script.sh"
        if [ -f "$_src" ]; then
            cp -f "$_src" "$_dst"
            chmod +x "$_dst"
        fi
    done

    cat > "$HOME/../usr/bin/umo" << UMOCMD
#!/bin/sh
_UMO_VERSION="3.3.9"
_UMO_REPO_DIR="${SCRIPT_DIR}"
UMOCMD
    cat >> "$HOME/../usr/bin/umo" << 'UMOCMD'
_UMO_NC='\033[0m'
_UMO_BOLD='\033[1m'
_UMO_DIM='\033[2m'
_UMO_PRI='\033[38;5;208m'
_UMO_CYN='\033[38;5;39m'
_UMO_GRN='\033[38;5;34m'
_UMO_RED='\033[38;5;196m'
_UMO_YEL='\033[38;5;220m'
_UMO_TERMUX_HOME="${HOME:-/data/data/com.termux/files/home}"

_umo_header() {
    printf "\n  ${_UMO_BOLD}${_UMO_PRI}▸ UMO${_UMO_NC}  ${_UMO_DIM}Ubuntu Modded Optimized${_UMO_NC}  ${_UMO_DIM}v${_UMO_VERSION}${_UMO_NC}\n"
    printf "  ${_UMO_PRI}────────────────────────────────────────${_UMO_NC}\n\n"
}

_umo_ok()   { printf "  ${_UMO_GRN}✔${_UMO_NC}  %s\n" "$1"; }
_umo_err()  { printf "  ${_UMO_RED}✖${_UMO_NC}  %s\n" "$1" >&2; }
_umo_info() { printf "  ${_UMO_CYN}➜${_UMO_NC}  %s\n" "$1"; }
_umo_warn() { printf "  ${_UMO_YEL}!${_UMO_NC}  %s\n" "$1"; }

_umo_status() {
    _umo_header
    _login="$_UMO_TERMUX_HOME/umo-login.sh"
    [ -f "$_login" ] && _installed="${_UMO_GRN}Installed${_UMO_NC}" || _installed="${_UMO_RED}Not installed${_UMO_NC}"
    printf "  ${_UMO_BOLD}Container:${_UMO_NC}  "
    printf "${_installed}\n"

    _proot_pids=$(pgrep -f "proot.*umo" 2>/dev/null | tr '\n' ' ')
    if [ -n "$_proot_pids" ]; then
        printf "  ${_UMO_BOLD}Session:${_UMO_NC}    ${_UMO_GRN}Running${_UMO_NC} (PID: $_proot_pids)\n"
    else
        printf "  ${_UMO_BOLD}Session:${_UMO_NC}    ${_UMO_DIM}Stopped${_UMO_NC}\n"
    fi

    _vnc_pid=$(pgrep -f "Xvnc" 2>/dev/null | head -1)
    if [ -n "$_vnc_pid" ]; then
        _ip=$(ip route get 1 2>/dev/null | awk '{print $7; exit}')
        [ -z "$_ip" ] && _ip="127.0.0.1"
        printf "  ${_UMO_BOLD}VNC:${_UMO_NC}        ${_UMO_GRN}Active${_UMO_NC} → ${_UMO_CYN}${_ip}:5901${_UMO_NC}\n"
    else
        printf "  ${_UMO_BOLD}VNC:${_UMO_NC}        ${_UMO_DIM}Stopped${_UMO_NC}\n"
    fi

    _pulse=$(pgrep -f "pulseaudio" 2>/dev/null | head -1)
    if [ -n "$_pulse" ]; then
        printf "  ${_UMO_BOLD}Audio:${_UMO_NC}      ${_UMO_GRN}Running${_UMO_NC}\n"
    else
        printf "  ${_UMO_BOLD}Audio:${_UMO_NC}      ${_UMO_DIM}Stopped${_UMO_NC}\n"
    fi
    printf "\n"
}

_umo_run_update() {
    _umo_info "Updating UMO from GitHub..."
    if [ -d "$_UMO_REPO_DIR/.git" ]; then
        cd "$_UMO_REPO_DIR" || exit 1
        git pull origin main || { _umo_err "Failed to update UMO."; exit 1; }
        _umo_ok "UMO has been updated successfully."
        _umo_info "You may need to run ./install.sh again to apply changes."
    else
        _umo_err "UMO was not installed via git clone. Cannot auto-update."
        exit 1
    fi
}

_umo_run_cmd() {
    if [ -z "$1" ]; then
        _umo_err "No command provided. Usage: umo run \"<command>\""
        exit 1
    fi
    "$_UMO_TERMUX_HOME/umo-login.sh" -c "$*"
}

_umo_set_user() {
    _new_user="$1"
    if [ -z "$_new_user" ]; then
        _umo_err "Usage: umo --user <username>"
        exit 1
    fi
    _login="$_UMO_TERMUX_HOME/umo-login.sh"
    _user_sh="$_UMO_TERMUX_HOME/umo-user.sh"
    if [ ! -f "$_login" ]; then
        _umo_err "UMO not installed."
        exit 1
    fi
    _umo_info "Switching default user to: $_new_user"
    "$_UMO_TERMUX_HOME/umo-login.sh" -c "id $_new_user >/dev/null 2>&1 || { useradd -m -s /bin/bash $_new_user && echo '${_new_user}:${_new_user}' | chpasswd; }"
    sed -i "s|/bin/su - [^ ]*|/bin/su - $_new_user|g" "$_user_sh" 2>/dev/null || true
    sed -i "s|HOME=/home/[^ ]*|HOME=/home/$_new_user|g" "$_user_sh" 2>/dev/null || true
    _umo_ok "Default user is now: $_new_user"
    _umo_info "Run 'umo user' to login as $_new_user"
}

_umo_backup() {
    _bak_dir="${1:-$_UMO_TERMUX_HOME/umo-backup}"
    _bak_file="$_bak_dir/umo-backup-$(date +%Y%m%d-%H%M%S).tar.gz"
    _install_dir=$(grep 'INSTALL_DIR=' "$_UMO_TERMUX_HOME/umo-login.sh" 2>/dev/null | head -1 | cut -d'"' -f2)
    if [ -z "$_install_dir" ] || [ ! -d "$_install_dir" ]; then
        _umo_err "Cannot find UMO install directory."
        exit 1
    fi
    mkdir -p "$_bak_dir"
    _umo_info "Backing up to: $_bak_file"
    tar -czf "$_bak_file" -C "$(dirname "$_install_dir")" "$(basename "$_install_dir")" 2>/dev/null
    _sz=$(du -sh "$_bak_file" 2>/dev/null | cut -f1)
    _umo_ok "Backup complete! Size: $_sz"
    _umo_info "File: $_bak_file"
}

_umo_help() {
    _umo_header
    printf "  ${_UMO_BOLD}USAGE:${_UMO_NC}\n"
    printf "    ${_UMO_CYN}umo${_UMO_NC} <command> [options]\n\n"

    printf "  ${_UMO_BOLD}COMMANDS:${_UMO_NC}\n"
    
    printf "  ${_UMO_DIM}Session Lifecycle${_UMO_NC}\n"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "start"              "Start Ubuntu + VNC + Audio session"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "stop"               "Terminate all UMO running processes"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "status"             "Display running status of services"
    printf "\n"

    printf "  ${_UMO_DIM}Terminal Access${_UMO_NC}\n"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "login"              "Start a root shell session"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "user"               "Start a default user shell session"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "run <cmd>"          "Execute a command inside Ubuntu"
    printf "\n"

    printf "  ${_UMO_DIM}System & Management${_UMO_NC}\n"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "vnc"                "Start the VNC server manually"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "update"             "Update UMO system from GitHub"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "backup [dir]"       "Create a tarball backup of the container"
    printf "\n"

    printf "  ${_UMO_BOLD}OPTIONS:${_UMO_NC}\n"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "--user <name>"      "Switch the default user and login"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "-h, --help"         "Print this help information"
    printf "    ${_UMO_CYN}%-20s${_UMO_NC} %s\n" "-v, --version"      "Print version information"
    printf "\n"

    printf "  ${_UMO_BOLD}EXAMPLES:${_UMO_NC}\n"
    printf "    ${_UMO_DIM}\$ umo login${_UMO_NC}                    # Login to container\n"
    printf "    ${_UMO_DIM}\$ umo run \"apt update\"${_UMO_NC}         # Run a command seamlessly\n"
    printf "    ${_UMO_DIM}\$ umo --user myuser${_UMO_NC}            # Switch user to 'myuser'\n"
    printf "    ${_UMO_DIM}\$ umo backup ~/backups${_UMO_NC}         # Backup rootfs to dir\n"
    printf "\n"
}

case "$1" in
    start)                  exec "$_UMO_TERMUX_HOME/umo-start.sh" "$2" ;;
    stop)                   exec "$_UMO_TERMUX_HOME/umo-stop.sh" ;;
    login)                  exec "$_UMO_TERMUX_HOME/umo-login.sh" ;;
    user)                   exec "$_UMO_TERMUX_HOME/umo-user.sh" ;;
    vnc)                    exec "$_UMO_TERMUX_HOME/umo-vnc-start.sh" ;;
    status)                 _umo_status ;;
    update)                 _umo_run_update ;;
    run)                    shift; _umo_run_cmd "$@" ;;
    backup)                 shift; _umo_backup "$@" ;;
    --user|-u)              shift; _umo_set_user "$1" ;;
    --version|-v|version)   printf "\n  ${_UMO_PRI}UMO${_UMO_NC} v${_UMO_VERSION}\n\n" ;;
    help|--help|-h)         _umo_help ;;
    "")
        _umo_err "No command provided."
        printf "  Run '${_UMO_CYN}umo --help${_UMO_NC}' for usage.\n\n"
        exit 1
        ;;
    *)
        _umo_err "Unknown command: $1"
        printf "  Run '${_UMO_CYN}umo --help${_UMO_NC}' for usage.\n\n"
        exit 1
        ;;
esac
UMOCMD
    chmod +x "$HOME/../usr/bin/umo"

    umo_log_ok "Finalized."
}

umo_phase_summary() {
    _ip=$(ip route get 1 2>/dev/null | awk '{print $7; exit}')
    [ -z "$_ip" ] && _ip="127.0.0.1"

    umo_screen_clear
    umo_banner
    umo_rule

    printf "\n  %b%bInstallation Complete%b\n" "$UMO_BOLD" "$UMO_COLOR_SUCCESS" "$UMO_NC"
    printf "  %b" "$UMO_COLOR_PRIMARY"
    umo_repeat "$UMO_LINE_H" 21
    printf "%b\n\n" "$UMO_NC"

    umo_kv "Version" "Ubuntu $UMO_UBUNTU_VERSION"
    umo_kv "Desktop" "$UMO_DE"
    umo_kv "Path"    "$UMO_INSTALL_DIR"
    umo_kv "VNC"     "$_ip:5901"
    umo_kv "User"    "umo (password: umo)"

    printf "\n  %b%bGet Started%b\n" "$UMO_BOLD" "$UMO_COLOR_PRIMARY" "$UMO_NC"
    printf "  %b" "$UMO_COLOR_PRIMARY"
    umo_repeat "$UMO_LINE_H" 11
    printf "%b\n\n" "$UMO_NC"

    printf "  %b%-28s%b %s\n" "$UMO_B_CYAN" "umo stop" "$UMO_NC" "Stop all services"
    printf "  %b%-28s%b %s\n" "$UMO_B_CYAN" "umo login" "$UMO_NC" "Login as root"
    printf "  %b%-28s%b %s\n" "$UMO_B_CYAN" "umo user" "$UMO_NC" "Login as default user"
    printf "  %b%-28s%b %s\n" "$UMO_B_CYAN" "umo --user <name>" "$UMO_NC" "Switch default user"
    printf "  %b%-28s%b %s\n" "$UMO_B_CYAN" "umo status" "$UMO_NC" "Show service status"
    printf "  %b%-28s%b %s\n" "$UMO_B_CYAN" "umo update" "$UMO_NC" "Update UMO script"
    printf "  %b%-28s%b %s\n" "$UMO_B_CYAN" "umo --help" "$UMO_NC" "Full command reference"

    _readme_dir="$UMO_INSTALL_DIR/root/.umo"
    umo_fs_mkdir "$_readme_dir" 2>/dev/null || true
    cat > "$_readme_dir/README.txt" 2>/dev/null || true << README_EOF
========================================
  UMO Ubuntu — v$UMO_VERSION
  Version: $UMO_UBUNTU_VERSION
  Desktop: $UMO_DE
========================================

Commands (run from Termux):
  umo stop             Stop all services
  umo login            Login as root
  umo user             Login as default user
  umo --user <name>    Switch user
  umo status           Show service status
  umo update           Update packages
  umo --help           Full help

VNC: $_ip:5901
User: umo / Password: umo

========================================
README_EOF

    printf "\n  %bRun %bumo --help%b%b for the full command reference.%b\n\n" "$UMO_DIM" "$UMO_B_CYAN" "$UMO_NC" "$UMO_DIM" "$UMO_NC"

    for _pid in $(pgrep -f "umo-login.sh" 2>/dev/null); do
        kill "$_pid" 2>/dev/null || true
    done
    for _pid in $(pgrep -f "proot.*umo" 2>/dev/null); do
        kill "$_pid" 2>/dev/null || true
    done
}

umo_cli_parse() {
    for _arg in "$@"; do
        case "$_arg" in
            --no-gui|--non-interactive) UMO_NON_INTERACTIVE=1 ;;
            --de=*)      UMO_DE="${_arg#*=}" ;;
            --apps=*)    UMO_APP_SET="${_arg#*=}" ;;
            --dir=*)     UMO_INSTALL_DIR="${_arg#*=}" ;;
            --ubuntu=*)  UMO_UBUNTU_VERSION="${_arg#*=}" ;;
            --version=*) UMO_UBUNTU_VERSION="${_arg#*=}" ;;
            --perf=*)    UMO_PERF_MODE="${_arg#*=}" ;;
            --theme=*)   UMO_THEME="${_arg#*=}" ;;
            --lean)      UMO_LEAN=1 ;;
            --help|-h)
                printf "\n  %bUbuntu Modded Optimized (UMO) Installer%b\n\n" "$UMO_BOLD" "$UMO_NC"
                printf "  %bUSAGE:%b\n" "$UMO_BOLD" "$UMO_NC"
                printf "    %bumo-install%b [OPTIONS]\n\n" "$UMO_B_CYAN" "$UMO_NC"
                
                printf "  %bOPTIONS:%b\n" "$UMO_BOLD" "$UMO_NC"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "-h, --help" "$UMO_NC" "Print help information"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "--no-gui, --non-interactive" "$UMO_NC" "Run in non-interactive mode"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "--lean" "$UMO_NC" "Remove docs/man/locales to save space"
                printf "\n"
                
                printf "  %bCONFIGURATION:%b\n" "$UMO_BOLD" "$UMO_NC"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "--de=<env>" "$UMO_NC" "Desktop environment (xfce4, lxde, openbox)"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "--apps=<set>" "$UMO_NC" "Application set (basic, dev, media, full)"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "--dir=<path>" "$UMO_NC" "Installation directory"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "--ubuntu=<version>" "$UMO_NC" "Ubuntu version (22.04, 24.04)"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "--perf=<mode>" "$UMO_NC" "Performance level (balanced, aggressive, off) [default: balanced]"
                printf "    %b%-30s%b %s\n" "$UMO_B_CYAN" "--theme=<theme>" "$UMO_NC" "Desktop theme (umo-dark, umo-light, minimal, none)"
                printf "\n"
                
                printf "  %bEXAMPLES:%b\n" "$UMO_BOLD" "$UMO_NC"
                printf "    %b\$ umo-install --no-gui --de=xfce4 --apps=full%b\n" "$UMO_DIM" "$UMO_NC"
                printf "    %b\$ umo-install --dir=/data/data/com.termux/files/home/ubuntu%b\n\n" "$UMO_DIM" "$UMO_NC"
                exit 0
                ;;
        esac
    done
}

. "$UMO_MOD_DIR/umo-perf.sh" 2>/dev/null || true

umo_phase_perf() {
    [ "$UMO_PERF_MODE" = "off" ] && { umo_log_info "Performance tuning disabled."; return 0; }
    umo_ui_header "Performance Tuning"
    export UMO_INSTALL_DIR
    export UMO_PERF_MODE
    export UMO_LEAN
    if command -v umo_perf_setup >/dev/null 2>&1; then
        umo_perf_setup
        umo_log_ok "Performance optimizations applied (mode: $UMO_PERF_MODE)."
    else
        umo_log_warn "Performance module not available, skipping."
    fi
}

. "$UMO_MOD_DIR/umo-theme.sh" 2>/dev/null || true

umo_phase_theme() {
    [ "$UMO_THEME" = "none" ] && { umo_log_info "Theme disabled."; return 0; }
    umo_ui_header "Desktop Theme"
    export UMO_INSTALL_DIR
    export UMO_THEME
    export SCRIPT_DIR
    if command -v umo_theme_setup >/dev/null 2>&1; then
        umo_theme_setup
        umo_log_ok "Desktop theme applied ($UMO_THEME)."
    else
        umo_log_warn "Theme module not available, skipping."
    fi
}

umo_main() {
    umo_cli_parse "$@"

    [ "$UMO_APP_SET" = "full" ] && [ -z "$UMO_THEME" ] && UMO_THEME="umo-dark"

    umo_phase_check
    umo_phase_deps
    umo_phase_config
    umo_phase_download
    umo_phase_proot
    umo_phase_perf
    umo_phase_vnc
    umo_phase_audio
    umo_phase_systemctl
    umo_phase_desktop
    umo_phase_apps
    umo_phase_theme
    umo_phase_finalize
    umo_phase_summary
}

umo_main "$@"
exit 0
